<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ADHDCompanionApp.Views.SupportPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Support">

    <ContentPage.ToolbarItems>
        <ToolbarItem
            IconImageSource="gear.svg"
            Order="Primary"
            Priority="0"
            Clicked="OnPreferencesClicked" />
    </ContentPage.ToolbarItems>

    <ScrollView x:Name="SupportScrollView">
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label
                Text="Support"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

            <Label
                Text="Let’s make this easier. Pick what feels closest right now."
                FontSize="16"
                Opacity="0.85"
                TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />

            <Label
                Text="Right now..."
                Style="{StaticResource SectionTitleStyle}" />

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout
                    Spacing="10"
                    BindableLayout.ItemsSource="{Binding SupportOptions}">

                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Frame
                                Padding="16"
                                Margin="0,6,0,0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                                BorderColor="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                                HasShadow="False">

                                <Frame.Triggers>
                                    <DataTrigger
                                        TargetType="Frame"
                                        Binding="{Binding IsSelected}"
                                        Value="True">
                                        <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                                        <Setter
                                            Property="BackgroundColor"
                                            Value="{AppThemeBinding Light={StaticResource SurfaceAltLight}, Dark={StaticResource SurfaceAltDark}}" />
                                    </DataTrigger>
                                </Frame.Triggers>

                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectSupportOptionCommand}"
                                        CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>

                                <VerticalStackLayout Spacing="4">
                                    <Label
                                        Text="{Binding Title}"
                                        FontSize="17"
                                        FontAttributes="Bold"
                                        TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                                    <Label
                                        Text="Tap for a small next step"
                                        FontSize="13"
                                        TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                                        Opacity="0.75" />
                                </VerticalStackLayout>

                            </Frame>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>

                </VerticalStackLayout>
            </Frame>

            <VerticalStackLayout
                x:Name="SupportPlanSection"
                IsVisible="{Binding HasSelectedOption}"
                Spacing="8">

                <Label
                    Text="Let’s take one step"
                    Style="{StaticResource SectionTitleStyle}" />

                <Frame Style="{StaticResource CardFrameStyle}">
                    <VerticalStackLayout Spacing="8">

                        <Label
                            Text="{Binding SelectedSupportTitle}"
                            FontSize="19"
                            FontAttributes="Bold"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                        <Label
                            Text="{Binding SelectedValidationText}"
                            FontSize="15"
                            LineBreakMode="WordWrap"
                            MaxLines="3"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                            Opacity="0.9" />

                        <Label
                            Text="Start here"
                            FontAttributes="Bold"
                            FontSize="14"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                            Opacity="0.85" />

                        <Label
                            Text="{Binding SelectedImmediateActionText}"
                            FontSize="15"
                            LineBreakMode="WordWrap"
                            MaxLines="3"
                            TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />

                        <Label
                            Text="Then just this"
                            FontAttributes="Bold"
                            FontSize="14"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                            Opacity="0.85" />

                        <Label
                            Text="{Binding SelectedNextStepText}"
                            FontSize="15"
                            LineBreakMode="WordWrap"
                            MaxLines="3"
                            TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />

                        <HorizontalStackLayout
                            Spacing="10"
                            Margin="0,8,0,0">

                            <Button
                                Text="Try a different step"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding TryAnotherStepCommand}" />

                            <Button
                                Text="That’s enough for now"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ClearSupportPlanCommand}" />

                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>

            <Label
                Text="Need a quick reset?"
                Style="{StaticResource SectionTitleStyle}"
                Margin="0,12,0,0" />

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="10">

                    <Label
                        Text="{Binding QuickResetText}"
                        FontSize="15"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                    <Button
                        Text="Help me reset"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ResetQuickSupportCommand}" />

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>