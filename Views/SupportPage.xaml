<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ADHDCompanionApp.Views.SupportPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Support">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label
                Text="Support"
                FontSize="28"
                FontAttributes="Bold" />

            <Label
                Text="What do you need help with right now?"
                FontSize="16"
                Opacity="0.8" />

            <Label
                Text="Quick Help"
                Style="{StaticResource SectionTitleStyle}" />

            <Frame Style="{StaticResource CardFrameStyle}">
                <CollectionView ItemsSource="{Binding SupportOptions}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Button
                                Text="{Binding Title}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,6,0,0"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectSupportOptionCommand}"
                                CommandParameter="{Binding .}" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Frame>

            <Label
                Text="Support Response"
                Style="{StaticResource SectionTitleStyle}" />

            <Frame Style="{StaticResource CardFrameStyle}">
                <Label
                    Text="{Binding SelectedSupportText}"
                    FontSize="16" />
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>