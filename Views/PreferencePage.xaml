<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ADHDCompanionApp.Views.PreferencesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Preferences"
    Shell.TabBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <Label
                Text="Preferences"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

            <Label
                Text="Update your name, reminders, and support settings."
                FontSize="14"
                TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="16">

                    <Label
                        Text="What should I call you?"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                    <Entry
                        Placeholder="Your name or nickname"
                        Text="{Binding Nickname}" />

                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="Do you want medication reminders?"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                        <Switch
                            IsToggled="{Binding UsesMedicationSupport}"
                            ThumbColor="{StaticResource Primary}"
                            OnColor="{StaticResource Primary}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout
                        IsVisible="{Binding UsesMedicationSupport}"
                        Spacing="10">

                        <Label
                            Text="What time would you like your reminder?"
                            TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />

                        <TimePicker
                            Time="{Binding ReminderTime}" />

                        <Label
                            Text="When should reminders start?"
                            TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />

                        <DatePicker
                            Date="{Binding MedicationStartDate}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="Do you want task support?"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                        <Switch
                            IsToggled="{Binding UsesTaskSupport}"
                            ThumbColor="{StaticResource Primary}"
                            OnColor="{StaticResource Primary}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="Show celebration when completing tasks?"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                        <Switch
                            IsToggled="{Binding EnableCelebration}"
                            ThumbColor="{StaticResource Primary}"
                            OnColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                    <Label
                        Text="{Binding StatusMessage}"
                        Style="{StaticResource StatusMessageStyle}" />

                    <Button
                        Text="Save Preferences"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" />

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>