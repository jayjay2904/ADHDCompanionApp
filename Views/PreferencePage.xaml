<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ADHDCompanionApp.Views.PreferencesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Preferences"
    Shell.TabBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <Label
                Text="Preferences"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

            <Label
                Text="Keep Arlo personal, helpful, and low-effort."
                FontSize="14"
                TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="18">

                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="What should Arlo call you?"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                        <Entry
                            Placeholder="Your name or nickname"
                            Text="{Binding Nickname}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="Medication reminders"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                        <Label
                            Text="Arlo can remind you when it’s time to take medication."
                            FontSize="13"
                            TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />

                        <Switch
                            IsToggled="{Binding UsesMedicationSupport}"
                            ThumbColor="{StaticResource Primary}"
                            OnColor="{StaticResource Primary}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout
                        IsVisible="{Binding UsesMedicationSupport}"
                        Spacing="10">

                        <Label
                            Text="Reminder time"
                            TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />

                        <TimePicker
                            Time="{Binding ReminderTime}" />

                        <Label
                            Text="Start date"
                            TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />

                        <DatePicker
                            Date="{Binding MedicationStartDate}" />

                    </VerticalStackLayout>

                    <Label
                        Text="General reminders are handled through Arlo when you mention something you need to remember."
                        FontSize="13"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />

                    <Label
                        Text="{Binding StatusMessage}"
                        Style="{StaticResource StatusMessageStyle}" />

                    <Button
                        Text="💾 Save Preferences"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" />
                    <Button
                        Text="❓ How To Use Arlo"
                        CornerRadius="22"
                        HeightRequest="50"
                        BackgroundColor="#F1E5FA"
                        TextColor="#24384A"
                        FontAttributes="Bold"
                        Clicked="HowToUseArlo_Clicked" />   

                    <Button
                        Text="ℹ️ About Arlo"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ShowAboutArloCommand}" /> 

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>