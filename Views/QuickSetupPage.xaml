<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ADHDCompanionApp.Views.QuickSetupPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <Label
                Text="Quick Setup"
                FontSize="24"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="16">

                    <Entry
                        Placeholder="Your name"
                        Text="{Binding Nickname}" />

                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="Do you want medication reminders?"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                        <Switch
                            IsToggled="{Binding UsesMedicationSupport}"
                            ThumbColor="{StaticResource Primary}"
                            OnColor="{StaticResource Primary}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout
                        IsVisible="{Binding UsesMedicationSupport}"
                        Spacing="10">

                        <Label
                            Text="What time would you like your reminder?"
                            TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />

                        <TimePicker
                            Time="{Binding ReminderTime}" />

                        <Label
                            Text="When should reminders start?"
                            TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />

                        <DatePicker
                            Date="{Binding MedicationStartDate}" />

                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="Do you want task support?"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                        <Switch
                            IsToggled="{Binding UsesTaskSupport}"
                            ThumbColor="{StaticResource Primary}"
                            OnColor="{StaticResource Primary}" />
                    </VerticalStackLayout>

                    <Button
                        Text="Continue"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" />

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>