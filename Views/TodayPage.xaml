<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ADHDCompanionApp.Views.TodayPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Today">
    
    <ContentPage.ToolbarItems>
        <ToolbarItem
        IconImageSource="gear.svg"
        Order="Primary"
        Priority="0"
        Clicked="OnPreferencesClicked" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label
                Text="{Binding GreetingText}"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="{StaticResource TextPrimary}" />

            <Label
                Text="{Binding FlowMessage}"
                FontSize="16"
                Opacity="0.8"
                TextColor="{StaticResource TextSecondary}" />

            <Label
                Text="Truth Bomb"
                Style="{StaticResource SectionTitleStyle}" />

            <Frame Style="{StaticResource CardFrameStyle}">
                <Label
                    Text="{Binding TruthBombText}"
                    FontSize="16"
                    TextColor="{StaticResource TextPrimary}" />
            </Frame>

            <Label
                Text="How are you feeling?"
                Style="{StaticResource SectionTitleStyle}" />

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="12">

                    <Entry
                        Placeholder="Mood (for example: good, low, anxious)"
                        Text="{Binding Mood}" />

                    <Label
                        Text="Energy"
                        TextColor="{StaticResource TextPrimary}" />

                    <Slider
                        Minimum="1"
                        Maximum="5"
                        Value="{Binding EnergyLevel}"
                        MinimumTrackColor="{StaticResource Primary}"
                        MaximumTrackColor="{StaticResource BorderColor}"
                        ThumbColor="{StaticResource Primary}" />

                    <Label
                        Text="{Binding EnergyLevel}"
                        TextColor="{StaticResource TextSecondary}" />

                    <Label
                        Text="Focus"
                        TextColor="{StaticResource TextPrimary}" />

                    <Slider
                        Minimum="1"
                        Maximum="5"
                        Value="{Binding FocusLevel}"
                        MinimumTrackColor="{StaticResource Primary}"
                        MaximumTrackColor="{StaticResource BorderColor}"
                        ThumbColor="{StaticResource Primary}" />

                    <Label
                        Text="{Binding FocusLevel}"
                        TextColor="{StaticResource TextSecondary}" />

                    <Editor
                        Placeholder="Optional note"
                        AutoSize="TextChanges"
                        Text="{Binding Note}" />

                    <Button
                        Text="Save check-in"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SaveCheckInCommand}" />

                    <Label 
                        Text="{Binding CheckInPrompt}" 
                        FontSize="16"
                        TextColor="{StaticResource InfoColor}"
                        HorizontalOptions="Center"
                        Margin="0,10,0,10" />

                </VerticalStackLayout>
            </Frame>

            <Label
                Text="Next Step"
                Style="{StaticResource SectionTitleStyle}" />

            <Frame Style="{StaticResource CardFrameStyle}">
                <Label
                    Text="{Binding NextStepSuggestion}"
                    TextColor="{StaticResource TextPrimary}" />
            </Frame>

            <Label
                Text="Tasks"
                Style="{StaticResource SectionTitleStyle}" />

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="12">

                    <Entry
                        Placeholder="Add a task"
                        Text="{Binding NewTaskTitle}" />

                    <Button
                        Text="Add task"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding AddTaskCommand}" />

                    <Label 
                        Text="{Binding StatusMessage}"
                        Style="{StaticResource StatusMessageStyle}"
                        HorizontalOptions="Center"
                        Margin="0,10,0,0" />

                    <CollectionView ItemsSource="{Binding Tasks}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame
                                    Padding="12"
                                    Margin="0,6,0,0"
                                    BackgroundColor="{StaticResource SurfaceColor}"
                                    BorderColor="{StaticResource BorderColor}"
                                    HasShadow="False">

                                    <VerticalStackLayout Spacing="6">

                                        <Grid ColumnDefinitions="*,Auto">

                                            <Label
                                                Grid.Column="0"
                                                Text="Tap to complete"
                                                FontSize="11"
                                                TextColor="{StaticResource TextSecondary}"
                                                Opacity="0.8"
                                                HorizontalOptions="Start">

                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleTaskCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Label.GestureRecognizers>

                                                <Label.Triggers>
                                                    <DataTrigger
                                                        TargetType="Label"
                                                        Binding="{Binding IsCompleted}"
                                                        Value="True">
                                                        <Setter Property="Text" Value="Completed" />
                                                    </DataTrigger>

                                                    <DataTrigger
                                                        TargetType="Label"
                                                        Binding="{Binding IsCompleted}"
                                                        Value="True">
                                                        <Setter Property="Opacity" Value="0.6" />
                                                    </DataTrigger>
                                                </Label.Triggers>

                                            </Label>

                                            <Label
                                                Grid.Column="1"
                                                Text="Set reminder"
                                                FontSize="11"
                                                TextColor="{StaticResource TextMuted}"
                                                HorizontalOptions="End">

                                                <Label.Triggers>
                                                    <DataTrigger
                                                        TargetType="Label"
                                                        Binding="{Binding IsCompleted}"
                                                        Value="True">
                                                        <Setter Property="IsVisible" Value="False" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>

                                        </Grid>

                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">

                                            <Label
                                                Grid.Column="0"
                                                Text="{Binding Title}"
                                                TextColor="{StaticResource TextPrimary}"
                                                FontSize="16"
                                                VerticalOptions="Center"
                                                LineBreakMode="WordWrap">

                                                <Label.Triggers>
                                                    <DataTrigger
                                                        TargetType="Label"
                                                        Binding="{Binding IsCompleted}"
                                                        Value="True">
                                                        <Setter Property="TextDecorations" Value="Strikethrough" />
                                                        <Setter Property="Opacity" Value="0.6" />
                                                    </DataTrigger>
                                                </Label.Triggers>

                                            </Label>

                                            <Switch
                                                Grid.Column="1"
                                                IsToggled="{Binding ReminderEnabled}"
                                                VerticalOptions="Center"
                                                OnColor="{StaticResource Primary}">

                                                <Switch.Triggers>
                                                    <DataTrigger
                                                        TargetType="Switch"
                                                        Binding="{Binding IsCompleted}"
                                                        Value="True">
                                                        <Setter Property="IsVisible" Value="False" />
                                                    </DataTrigger>
                                                </Switch.Triggers>

                                                <Switch.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleTaskReminderCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Switch.GestureRecognizers>
                                            </Switch>

                                        </Grid>

                                        <Label
                                            FontSize="12"
                                            TextColor="{StaticResource TextMuted}"
                                            Text="{Binding ReminderDateTime, StringFormat='Reminder: {0:dd MMM yyyy HH:mm}'}">

                                            <Label.Triggers>
                                                <DataTrigger
                                                    TargetType="Label"
                                                    Binding="{Binding IsCompleted}"
                                                    Value="True">
                                                    <Setter Property="IsVisible" Value="False" />
                                                </DataTrigger>

                                                <DataTrigger
                                                    TargetType="Label"
                                                    Binding="{Binding ReminderEnabled}"
                                                    Value="False">
                                                    <Setter Property="IsVisible" Value="False" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                        <VerticalStackLayout
                                            Spacing="6"
                                            IsVisible="{Binding IsEditingReminder}">

                                            <VerticalStackLayout.Triggers>
                                                <DataTrigger
                                                    TargetType="VerticalStackLayout"
                                                    Binding="{Binding IsCompleted}"
                                                    Value="True">
                                                    <Setter Property="IsVisible" Value="False" />
                                                </DataTrigger>
                                            </VerticalStackLayout.Triggers>

                                            <DatePicker Date="{Binding ReminderDate}" />
                                            <TimePicker Time="{Binding ReminderTime}" />

                                            <Button
                                                Text="Save reminder"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SaveTaskReminderCommand}"
                                                CommandParameter="{Binding .}" />

                                        </VerticalStackLayout>

                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

            <Label
                Text="Today's Win"
                Style="{StaticResource SectionTitleStyle}" />

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="12">

                    <Editor
                        Placeholder="What’s one win from today?"
                        AutoSize="TextChanges"
                        Text="{Binding NewWinText}" />

                    <Button
                        Text="Save win"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding AddWinCommand}" />

                    <Label
                        Text="Recent Wins"
                        FontAttributes="Bold"
                        Margin="0,8,0,0"
                        TextColor="{StaticResource TextPrimary}" />

                    <CollectionView ItemsSource="{Binding RecentWins}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame
                                    Padding="12"
                                    Margin="0,6,0,0"
                                    BackgroundColor="{StaticResource SurfaceColor}"
                                    BorderColor="{StaticResource BorderColor}"
                                    HasShadow="False">
                                    <VerticalStackLayout Spacing="4">
                                        <Label
                                            Text="{Binding Text}"
                                            TextColor="{StaticResource TextPrimary}" />
                                        <Label
                                            Text="{Binding TimestampUtc, StringFormat='Saved: {0:dd MMM yyyy HH:mm}'}"
                                            FontSize="12"
                                            TextColor="{StaticResource TextMuted}"
                                            Opacity="0.8" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

            <Label
                Text="{Binding StatusMessage}"
                Style="{StaticResource StatusMessageStyle}"
                Opacity="0.9"
                Margin="0,8,0,16" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>