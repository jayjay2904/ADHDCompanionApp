<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ADHDCompanionApp.Views.ArloPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:helpers="clr-namespace:ADHDCompanionApp.Helpers"
    Title="Arlo"
    BackgroundColor="#121212">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20" RowSpacing="16">

        <!-- HEADER + QUICK PROMPTS -->
        <VerticalStackLayout Grid.Row="0" Spacing="8">

            <Label
                Text="Hi I'm Arlo"
                TextColor="White"
                FontSize="28"
                FontAttributes="Bold" />

            <Label
                Text="How can I help? Would you like to talk it through."
                FontSize="16"
                Opacity="0.8"
                TextColor="White"/>

            <Button
                Text="Clear chat"
                Style="{StaticResource SecondaryButtonStyle}"
                Command="{Binding ClearChatCommand}" />

            <CollectionView
                ItemsSource="{Binding QuickPrompts}"
                ItemsLayout="HorizontalList"
                SelectionMode="None"
                HeightRequest="50"
                IsVisible="{Binding AreQuickPromptsVisible}">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Button
                            Text="{Binding .}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SendQuickPromptCommand}"
                            CommandParameter="{Binding .}" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>

        <!-- CONVERSATION CARD -->
        <Frame
            Grid.Row="1"
            Style="{StaticResource CardFrameStyle}"
            Padding="12">

            <Grid RowDefinitions="Auto,*" RowSpacing="8">

                <Label
                    Grid.Row="0"
                    Text="Conversation"
                    FontSize="16"
                    FontAttributes="Bold"
                    TextColor="White"/>

                <ScrollView
                    x:Name="MessagesScrollView"
                    Grid.Row="1">

                    <VerticalStackLayout
                        x:Name="MessagesStack"
                        Spacing="8"
                        BindableLayout.ItemsSource="{Binding Messages}">

                        <BindableLayout.ItemTemplateSelector>
                            <helpers:ChatMessageTemplateSelector>

                                <!-- ARLO MESSAGE -->
                                <helpers:ChatMessageTemplateSelector.ArloTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Frame
                                                Padding="14"
                                                CornerRadius="16"
                                                HasShadow="False"
                                                BackgroundColor="Transparent"
                                                BorderColor="{StaticResource Primary}"
                                                HorizontalOptions="Start"
                                                Margin="0,0,40,0">

                                                <Label
                                                    Text="{Binding Text}"
                                                    TextColor="White"
                                                    FontSize="16"
                                                    LineBreakMode="WordWrap" />
                                            </Frame>
                                        </Grid>
                                    </DataTemplate>
                                </helpers:ChatMessageTemplateSelector.ArloTemplate>

                                <!-- USER MESSAGE -->
                                <helpers:ChatMessageTemplateSelector.UserTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Frame
                                                Padding="14"
                                                CornerRadius="16"
                                                HasShadow="False"
                                                BackgroundColor="{StaticResource Primary}"
                                                HorizontalOptions="End"
                                                Margin="40,0,0,0">

                                                <Label
                                                    Text="{Binding Text}"
                                                    FontSize="16"
                                                    TextColor="White"
                                                    LineBreakMode="WordWrap"
                                                    />
                                            </Frame>
                                        </Grid>
                                    </DataTemplate>
                                </helpers:ChatMessageTemplateSelector.UserTemplate>

                            </helpers:ChatMessageTemplateSelector>
                        </BindableLayout.ItemTemplateSelector>

                    </VerticalStackLayout>

                </ScrollView>

            </Grid>

        </Frame>

        <!-- INPUT CARD -->
        <Frame
            Grid.Row="2"
            Style="{StaticResource CardFrameStyle}"
            Padding="12">

            <VerticalStackLayout Spacing="8">

                <Editor
                    Placeholder="Tell Arlo what’s going on..."
                    AutoSize="TextChanges"
                    Text="{Binding UserInput}"
                    MinimumHeightRequest="80" />

                <Button
                    Text="Send"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding SendMessageCommand}" />

            </VerticalStackLayout>

        </Frame>

    </Grid>
</ContentPage>