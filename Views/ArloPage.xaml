<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ADHDCompanionApp.Views.ArloPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:helpers="clr-namespace:ADHDCompanionApp.Helpers"
    Title="Arlo">

    <ContentPage.Resources>
        <helpers:ArloPromptColourConverter x:Key="ArloPromptColourConverter" />
        <helpers:InverseBoolConverter x:Key="InverseBoolConverter" />
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem
            IconImageSource="gear.svg"
            Order="Primary"
            Priority="0"
            Clicked="OnPreferencesClicked" />
    </ContentPage.ToolbarItems>

    <Grid>

        <Grid RowDefinitions="Auto,*,Auto" Padding="20" RowSpacing="8">

            <!-- Header + First-Time Quick Prompts -->
            <VerticalStackLayout
                Grid.Row="0"
                Spacing="2"
                IsVisible="{Binding AreQuickPromptsVisible}">

                <VerticalStackLayout
                    Spacing="-8"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">   

                    <Image
                        Source="arlo_main.png"
                        HeightRequest="140"
                        WidthRequest="140"
                        Aspect="AspectFit" />

                    <VerticalStackLayout Spacing="0" VerticalOptions="Start" Margin="0">

                        <Label
                            Text="{Binding GreetingText}"
                            FontSize="26"
                            FontAttributes="Bold"
                            LineBreakMode="WordWrap"
                            MaxLines="3"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                        <Label
                            Text="Pick what fits, or tell me what’s going on."
                            FontSize="12"
                            Opacity="0.8"
                            TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />

                    </VerticalStackLayout>

                </VerticalStackLayout>

                <CollectionView
                    ItemsSource="{Binding QuickPrompts}"
                    SelectionMode="None"
                    HeightRequest="200"
                    Margin="0,8,0,20">  

                    <CollectionView.ItemsLayout>
                        <GridItemsLayout
                            Orientation="Vertical"
                            Span="2"
                            HorizontalItemSpacing="10"
                            VerticalItemSpacing="10" /> 
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame
                                Padding="10,6"
                                CornerRadius="20"
                                HasShadow="False"
                                HeightRequest="42"
                                Margin="0,2"
                                BackgroundColor="{Binding Text, Converter={StaticResource ArloPromptColourConverter}}"> 

                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Tapped="OnQuickPromptTapped"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SendQuickPromptCommand}"
                                        CommandParameter="{Binding Text}" />    
                                </Frame.GestureRecognizers>

                                <HorizontalStackLayout
                                    Spacing="4"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center">   

                                    <Image
                                        Source="{Binding Icon}"
                                        HeightRequest="22"
                                        WidthRequest="22"
                                        VerticalOptions="Center"
                                        Margin="0,0,2,0" /> 

                                    <Label
                                        Text="{Binding Text}"
                                        FontSize="14"
                                        TextColor="#2E2E2E"
                                        LineBreakMode="TailTruncation"
                                        VerticalTextAlignment="Center" />   

                                </HorizontalStackLayout>

                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>

            </VerticalStackLayout>

            <!-- Conversation -->
            <Frame
                Grid.Row="1"
                Style="{StaticResource CardFrameStyle}"
                Padding="12"
                VerticalOptions="FillAndExpand"
                IsVisible="{Binding AreQuickPromptsVisible, Converter={StaticResource InverseBoolConverter}}">

                <Grid RowDefinitions="Auto,*" RowSpacing="8">

                    <Label
                        Grid.Row="0"
                        Text="Conversation"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                    <ScrollView
                        x:Name="MessagesScrollView"
                        Grid.Row="1">

                        <VerticalStackLayout
                            x:Name="MessagesStack"
                            Spacing="12"
                            BindableLayout.ItemsSource="{Binding Messages}">

                            <BindableLayout.ItemTemplateSelector>
                                <helpers:ChatMessageTemplateSelector>

                                    <helpers:ChatMessageTemplateSelector.ArloTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">

                                                <Image
                                                    Grid.Column="0"
                                                    Source="arlo2.png"
                                                    HeightRequest="60"
                                                    WidthRequest="60"
                                                    VerticalOptions="Start"
                                                    Aspect="AspectFit" />

                                                <Frame
                                                    Grid.Column="1"
                                                    Style="{StaticResource ArloBubbleStyle}"
                                                    MaximumWidthRequest="280">

                                                    <Label
                                                        Text="{Binding Text}"
                                                        TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                                        FontSize="16"
                                                        LineBreakMode="WordWrap" />

                                                </Frame>

                                            </Grid>
                                        </DataTemplate>
                                    </helpers:ChatMessageTemplateSelector.ArloTemplate>

                                    <helpers:ChatMessageTemplateSelector.UserTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*,Auto">

                                                <Frame
                                                    Grid.Column="1"
                                                    Style="{StaticResource UserBubbleStyle}"
                                                    MaximumWidthRequest="280">

                                                    <Label
                                                        Text="{Binding Text}"
                                                        FontSize="16"
                                                        TextColor="#2E2E2E"
                                                        LineBreakMode="WordWrap" />

                                                </Frame>

                                            </Grid>
                                        </DataTemplate>
                                    </helpers:ChatMessageTemplateSelector.UserTemplate>

                                </helpers:ChatMessageTemplateSelector>
                            </BindableLayout.ItemTemplateSelector>

                        </VerticalStackLayout>

                    </ScrollView>

                </Grid>

            </Frame>

            <!-- Chat-style Input -->
            <Frame
                Grid.Row="2"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                BorderColor="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                CornerRadius="28"
                Padding="8"
                HasShadow="False"
                VerticalOptions="End">  

                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">

                    <!-- Prompt picker button -->
                    <Button
                        Grid.Column="0"
                        Text="+"
                        WidthRequest="44"
                        HeightRequest="44"
                        CornerRadius="22"
                        Padding="0"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                        FontSize="26"
                        FontAttributes="Bold"
                        Command="{Binding ShowPromptsCommand}"
                        Pressed="OnPromptPlusPressed"
                        Released="OnPromptPlusReleased" />  

                    <!-- Text input -->
                    <Entry
                        x:Name="UserInputEntry"
                        Grid.Column="1"
                        Placeholder="What’s going on?"
                        Text="{Binding UserInput}"
                        ReturnType="Send"
                        Completed="OnUserInputCompleted"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                    
                    <!-- Speech to text button  -->
                    <ImageButton
                        Grid.Column="2"
                        Source="mic.png"
                        WidthRequest="22"
                        HeightRequest="22"
                        BackgroundColor="Transparent"
                        Command="{Binding ListenCommand}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Padding="0" />     

                    <!-- Send button -->
                    <Button
                        Grid.Column="3"
                        Text="➜"
                        WidthRequest="44"
                        HeightRequest="44"
                        CornerRadius="22"
                        Padding="0"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="#F5F1E8"
                        FontSize="22"
                        FontAttributes="Bold"
                        Command="{Binding SendMessageCommand}"
                        Pressed="OnSendButtonPressed"
                        Released="OnSendButtonReleased" />  

                </Grid>

            </Frame>

        </Grid>

        <!-- Prompt Picker Overlay -->
        <Grid
            BackgroundColor="#80000000"
            IsVisible="{Binding ArePromptPickerVisible}"
            InputTransparent="{Binding ArePromptPickerVisible, Converter={StaticResource InverseBoolConverter}}">

            <Frame
                VerticalOptions="End"
                Margin="20"
                Padding="16"
                CornerRadius="24"
                Style="{StaticResource CardFrameStyle}">

                <VerticalStackLayout Spacing="12">

                    <Label
                        Text="What fits now?"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                    <Label
                        Text="Pick another option and I’ll keep going from there."
                        FontSize="13"
                        Opacity="0.8"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />

                    <CollectionView
                        ItemsSource="{Binding QuickPrompts}"
                        SelectionMode="None"
                        HeightRequest="200">

                        <CollectionView.ItemsLayout>
                            <GridItemsLayout
                                Orientation="Vertical"
                                Span="2"
                                HorizontalItemSpacing="8"
                                VerticalItemSpacing="6" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame
                                    Padding="10,6"
                                    CornerRadius="20"
                                    HasShadow="False"
                                    HeightRequest="42"
                                    BackgroundColor="{Binding Text, Converter={StaticResource ArloPromptColourConverter}}">

                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Tapped="OnQuickPromptTapped"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SendQuickPromptCommand}"
                                            CommandParameter="{Binding Text}" />
                                    </Frame.GestureRecognizers>

                                    <HorizontalStackLayout
                                        Spacing="4"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center">

                                        <Image
                                            Source="{Binding Icon}"
                                            HeightRequest="22"
                                            WidthRequest="22"
                                            VerticalOptions="Center"
                                            Margin="0,0,2,0" />

                                        <Label
                                            Text="{Binding Text}"
                                            FontSize="13"
                                            TextColor="#2E2E2E"
                                            LineBreakMode="TailTruncation"
                                            VerticalTextAlignment="Center" />

                                    </HorizontalStackLayout>

                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                    <Button
                        Text="Cancel"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding HidePromptPickerCommand}" />

                    <Button
                        Text="Clear chat"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ClearChatCommand}" />

                </VerticalStackLayout>

            </Frame>

        </Grid>

    </Grid>

</ContentPage>