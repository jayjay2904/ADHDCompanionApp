<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    x:Class="ADHDCompanionApp.Views.ProgressSummaryPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">

    <Frame
        WidthRequest="340"
        Padding="16"
        CornerRadius="24"
        Style="{StaticResource CardFrameStyle}">

        <VerticalStackLayout Spacing="12">

            <Grid ColumnDefinitions="*,Auto">

                <VerticalStackLayout Grid.Column="0" Spacing="2">

                    <Label
                        Text="Your progress"
                        FontSize="22"
                        FontAttributes="Bold" />

                    <Label
                        Text="A gentle look at what Arlo has noticed."
                        FontSize="13"
                        Opacity="0.8" />

                </VerticalStackLayout>

                <Button
                    Grid.Column="1"
                    Text="✕"
                    FontSize="18"
                    WidthRequest="40"
                    HeightRequest="40"
                    Padding="0"
                    CornerRadius="20"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="#2E2E2E"
                    Clicked="OnCloseClicked" />

            </Grid>

            <Frame
                BorderColor="{StaticResource Primary}"
                BackgroundColor="Transparent"
                CornerRadius="18"
                Padding="12"
                HasShadow="False"
                HeightRequest="190">

                <VerticalStackLayout Spacing="4">

                    <Label
                        Text="Recent wins"
                        FontSize="17"
                        FontAttributes="Bold" />

                    <CollectionView
                        ItemsSource="{Binding RecentWins}"
                        HeightRequest="140">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label
                                    Text="{Binding Text}"
                                    FontSize="14"
                                    Margin="0,2" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </VerticalStackLayout>

            </Frame>

            <Frame
                BorderColor="{StaticResource Primary}"
                BackgroundColor="Transparent"
                CornerRadius="18"
                Padding="12"
                HasShadow="False"
                HeightRequest="190">

                <VerticalStackLayout Spacing="4">

                    <Label
                        Text="Recent check-ins"
                        FontSize="17"
                        FontAttributes="Bold" />

                    <CollectionView
                        ItemsSource="{Binding RecentCheckIns}"
                        HeightRequest="140">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label
                                    Text="{Binding Mood}"
                                    FontSize="14"
                                    Margin="0,2" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>

    </Frame>

</toolkit:Popup>