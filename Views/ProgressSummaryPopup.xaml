<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    x:Class="ADHDCompanionApp.Views.ProgressSummaryPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">

    <Frame
        WidthRequest="340"
        Padding="16"
        CornerRadius="24"
        Style="{StaticResource CardFrameStyle}">

        <ScrollView HeightRequest="520">
            <VerticalStackLayout Spacing="2">

                <Grid ColumnDefinitions="*,Auto">

                    <VerticalStackLayout Grid.Column="0" Spacing="2">

                        <Label
                            Text="Your progress"
                            FontSize="22"
                            FontAttributes="Bold" />    

                        <Label
                            Text="A gentle look at what Arlo has noticed."
                            FontSize="13"   
                            Opacity="0.8" />    

                    </VerticalStackLayout>

                    <Button
                        Grid.Column="1"
                        Text="✕"
                        FontSize="18"
                        WidthRequest="40"
                        HeightRequest="40"
                        Padding="0"
                        CornerRadius="20"
                        BackgroundColor="#B3CF99"
                        Clicked="OnCloseClicked" /> 

                </Grid>

                <Label Text="Recent wins" FontSize="17" FontAttributes="Bold" />
                <Label Text="{Binding WinsSummary}" />
                <CollectionView ItemsSource="{Binding RecentWins}" HeightRequest="110">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Label Text="{Binding Text}" FontSize="14" Margin="0,4" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Recent check-ins" FontSize="17" FontAttributes="Bold" />
                <Label Text="{Binding CheckInSummary}" />
                <CollectionView ItemsSource="{Binding RecentCheckIns}" HeightRequest="110">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Label Text="{Binding Mood}" FontSize="14" Margin="0,4" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!--<Label Text="Open small steps" FontSize="17" FontAttributes="Bold" />
                <Label Text="{Binding TasksSummary}" />
                <CollectionView ItemsSource="{Binding OpenTasks}" HeightRequest="110">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Label Text="{Binding Title}" FontSize="14" Margin="0,4" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>-->

            </VerticalStackLayout>
        </ScrollView>
    </Frame>
</toolkit:Popup>