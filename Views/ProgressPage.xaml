<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ADHDCompanionApp.Views.ProgressPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Progress">

    <ContentPage.ToolbarItems>
        <ToolbarItem
            IconImageSource="gear.svg"
            Order="Primary"
            Priority="0"
            Clicked="OnPreferencesClicked" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label
                Text="Progress"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

            <Label
                Text="A gentle look at how things are going."
                FontSize="16"
                Opacity="0.8"
                TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />

            <Label
                Text="Your Progress"
                Style="{StaticResource SectionTitleStyle}" />

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="12">

                    <Frame Style="{StaticResource CardFrameStyle}">
                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="Check-ins logged"
                                FontAttributes="Bold"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                            <Label
                                Text="{Binding TotalCheckIns}"
                                FontSize="20"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Style="{StaticResource CardFrameStyle}">
                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="Tasks created"
                                FontAttributes="Bold"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                            <Label
                                Text="{Binding TotalTasks}"
                                FontSize="20"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Style="{StaticResource CardFrameStyle}">
                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="Tasks completed"
                                FontAttributes="Bold"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                            <Label
                                Text="{Binding CompletedTasks}"
                                FontSize="20"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Style="{StaticResource CardFrameStyle}">
                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="Wins captured"
                                FontAttributes="Bold"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                            <Label
                                Text="{Binding TotalWins}"
                                FontSize="20"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                        </VerticalStackLayout>
                    </Frame>

                </VerticalStackLayout>
            </Frame>

            <Label
                Text="Recent Wins"
                Style="{StaticResource SectionTitleStyle}" />

            <Frame Style="{StaticResource CardFrameStyle}">
                <CollectionView ItemsSource="{Binding RecentWins}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame
                                Padding="12"
                                Margin="0,6,0,0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                                BorderColor="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                                HasShadow="False">

                                <VerticalStackLayout Spacing="4">
                                    <Label
                                        Text="{Binding Text}"
                                        TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                                    <Label
                                        Text="{Binding TimestampUtc, StringFormat='Saved: {0:dd MMM yyyy HH:mm}'}"
                                        FontSize="12"
                                        TextColor="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}"
                                        Opacity="0.6" />
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>