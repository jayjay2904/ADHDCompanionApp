<?xml version="1.0" encoding="utf-8" ?>
<Shell
    x:Class="ADHDCompanionApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ADHDCompanionApp.Views">

    <TabBar>
        <ShellContent
            Title="Today"
            Route="TodayPage"
            ContentTemplate="{DataTemplate views:TodayPage}" />

        <ShellContent
            Title="Support"
            Route="SupportPage"
            ContentTemplate="{DataTemplate views:SupportPage}" />

        <ShellContent
            Title="Progress"
            Route="ProgressPage"
            ContentTemplate="{DataTemplate views:ProgressPage}" />

        <ShellContent
            Title="Arlo"
            Route="ArloPage"
            ContentTemplate="{DataTemplate views:ArloPage}" />
    </TabBar>
</Shell>