<?xml version="1.0" encoding="utf-8" ?>
<Application
    x:Class="ADHDCompanionApp.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:ADHDCompanionApp.Converters">

    <Application.Resources>
        <ResourceDictionary>

            <!-- Brand -->
            <Color x:Key="Primary">#B3CF99</Color>
            <Color x:Key="PrimaryDark">#98B67F</Color>
            <Color x:Key="PrimaryLight">#D6E4C8</Color>

            <!-- Feedback -->
            <Color x:Key="CoralColor">#D97C73</Color>
            <Color x:Key="CoralSoft">#E8B4AE</Color>
            <Color x:Key="InfoColor">#7D9AB5</Color>
            <Color x:Key="SuccessColor">#7FA36A</Color>
            <Color x:Key="WarningColor">#C9A95C</Color>

            <!-- Light theme -->
            <Color x:Key="BackgroundLight">#F2E8D8</Color>
            <Color x:Key="CardLight">#FFFDF8</Color>
            <Color x:Key="SurfaceLight">#FFFDF8</Color>
            <Color x:Key="SurfaceAltLight">#FAF4EA</Color>
            <Color x:Key="BorderLight">#E8DECD</Color>

            <Color x:Key="TextPrimaryLight">#2E2E2E</Color>
            <Color x:Key="TextSecondaryLight">#6B6B6B</Color>
            <Color x:Key="TextMutedLight">#9A948A</Color>

            <!-- Dark theme -->
            <Color x:Key="BackgroundDark">#2A241D</Color>
            <Color x:Key="CardDark">#342D25</Color>
            <Color x:Key="SurfaceDark">#342D25</Color>
            <Color x:Key="SurfaceAltDark">#3C342B</Color>
            <Color x:Key="BorderDark">#4A4035</Color>

            <Color x:Key="TextPrimaryDark">#F3EBDD</Color>
            <Color x:Key="TextSecondaryDark">#D8CCBC</Color>
            <Color x:Key="TextMutedDark">#B7AA98</Color>

            <!-- Brushes -->
            <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />

            <!-- Page Defaults -->
            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor"
                        Value="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}" />
            </Style>

            <!-- Label Defaults -->
            <Style TargetType="Label">
                <Setter Property="TextColor"
                        Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
            </Style>

            <!-- Entry Defaults -->
            <Style TargetType="Entry">
                <Setter Property="TextColor"
                        Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                <Setter Property="PlaceholderColor"
                        Value="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                <Setter Property="BackgroundColor"
                        Value="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" />
                <Setter Property="Margin" Value="0,2,0,0" />
            </Style>

            <!-- Editor Defaults -->
            <Style TargetType="Editor">
                <Setter Property="TextColor"
                        Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                <Setter Property="PlaceholderColor"
                        Value="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                <Setter Property="BackgroundColor"
                        Value="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" />
                <Setter Property="Margin" Value="0,2,0,0" />
            </Style>

            <!-- DatePicker Defaults -->
            <Style TargetType="DatePicker">
                <Setter Property="TextColor"
                        Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                <Setter Property="BackgroundColor"
                        Value="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" />
            </Style>

            <!-- TimePicker Defaults -->
            <Style TargetType="TimePicker">
                <Setter Property="TextColor"
                        Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                <Setter Property="BackgroundColor"
                        Value="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" />
            </Style>

            <!-- Card Frame -->
            <Style TargetType="Frame" x:Key="CardFrameStyle">
                <Setter Property="Padding" Value="16" />
                <Setter Property="Margin" Value="0,4,0,0" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="HasShadow" Value="True" />
                <Setter Property="BackgroundColor"
                        Value="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}" />
                <Setter Property="BorderColor"
                        Value="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" />
                <Setter Property="Shadow">
                    <Setter.Value>
                        <Shadow
                            Brush="#30000000"
                            Offset="0,10"
                            Radius="28"
                            Opacity="0.5" />
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Section Title -->
            <Style TargetType="Label" x:Key="SectionTitleStyle">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="Margin" Value="0,8,0,0" />
                <Setter Property="TextColor"
                        Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                <Setter Property="Opacity" Value="0.95" />
            </Style>

            <!-- Subtitle / Help Text -->
            <Style TargetType="Label" x:Key="SubtitleLabelStyle">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor"
                        Value="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                <Setter Property="Opacity" Value="0.9" />
            </Style>

            <!-- Muted Label -->
            <Style TargetType="Label" x:Key="MutedLabelStyle">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextColor"
                        Value="{AppThemeBinding Light={StaticResource TextMutedLight}, Dark={StaticResource TextMutedDark}}" />
                <Setter Property="Opacity" Value="0.9" />
            </Style>

            <!-- Primary Button -->
            <Style TargetType="Button" x:Key="PrimaryButtonStyle">
                <Setter Property="Margin" Value="0,10,0,0" />
                <Setter Property="Padding" Value="14,10" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                <Setter Property="TextColor" Value="#2E2E2E" />
            </Style>

            <!-- Secondary Button -->
            <Style TargetType="Button" x:Key="SecondaryButtonStyle">
                <Setter Property="Margin" Value="0,6,6,0" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="BackgroundColor"
                        Value="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" />
                <Setter Property="BorderColor"
                        Value="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="TextColor"
                        Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
            </Style>

            <!-- Status Message -->
            <Style TargetType="Label" x:Key="StatusMessageStyle">
                <Setter Property="TextColor" Value="{StaticResource CoralColor}" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <!-- Success Message -->
            <Style TargetType="Label" x:Key="SuccessMessageStyle">
                <Setter Property="TextColor" Value="{StaticResource SuccessColor}" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <!-- Arlo Bubble -->
            <Style TargetType="Frame" x:Key="ArloBubbleStyle">
                <Setter Property="Padding" Value="12" />
                <Setter Property="Margin" Value="0,4,0,0" />
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="HasShadow" Value="True" />
                <Setter Property="HorizontalOptions" Value="FillAndExpand" />
                <Setter Property="BackgroundColor"
                    Value="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" />
                <Setter Property="BorderColor"
                    Value="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" />
                <Setter Property="Shadow">
                    <Setter.Value>
                        <Shadow
                Brush="#12000000"
                Offset="0,3"
                Radius="10"
                Opacity="0.22" />
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- User Bubble -->
            <Style TargetType="Frame" x:Key="UserBubbleStyle">
                <Setter Property="Padding" Value="14" />
                <Setter Property="Margin" Value="40,6,0,0" />
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="HasShadow" Value="True" />
                <Setter Property="BackgroundColor" Value="{StaticResource PrimaryLight}" />
                <Setter Property="BorderColor"
                        Value="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" />
                <Setter Property="HorizontalOptions" Value="End" />
                <Setter Property="Shadow">
                    <Setter.Value>
                        <Shadow
                            Brush="#12000000"
                            Offset="0,3"
                            Radius="10"
                            Opacity="0.22" />
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>