<?xml version="1.0" encoding="utf-8" ?>
<Application
    x:Class="ADHDCompanionApp.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Application.Resources>
        <ResourceDictionary>

            <!-- Core Palette -->
            <Color x:Key="Primary">#B3CF99</Color>
            <Color x:Key="PrimaryDark">#8FAE7B</Color>
            <Color x:Key="PrimaryLight">#D4E6C6</Color>

            <Color x:Key="CoralColor">#FF8A80</Color>
            <Color x:Key="CoralSoft">#FFB3AB</Color>

            <Color x:Key="BackgroundColor">#121212</Color>
            <Color x:Key="CardColor">#1A1F1A</Color>
            <Color x:Key="SurfaceColor">#222822</Color>
            <Color x:Key="BorderColor">#2E352E</Color>

            <Color x:Key="TextPrimary">#FFFFFF</Color>
            <Color x:Key="TextSecondary">#B8C2B8</Color>
            <Color x:Key="TextMuted">#7F8A7F</Color>

            <Color x:Key="InfoColor">#7FA7D8</Color>
            <Color x:Key="SuccessColor">#9CCC8A</Color>
            <Color x:Key="WarningColor">#E6C777</Color>

            <!-- Brushes -->
            <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
            <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
            <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />

            <!-- Page Defaults -->
            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor" Value="{StaticResource BackgroundColor}" />
            </Style>

            <!-- Label Defaults -->
            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
            </Style>

            <!-- Entry Defaults -->
            <Style TargetType="Entry">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
                <Setter Property="BackgroundColor" Value="{StaticResource SurfaceColor}" />
                <Setter Property="Margin" Value="0,2,0,0" />
            </Style>

            <!-- Editor Defaults -->
            <Style TargetType="Editor">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
                <Setter Property="BackgroundColor" Value="{StaticResource SurfaceColor}" />
                <Setter Property="Margin" Value="0,2,0,0" />
            </Style>

            <!-- DatePicker Defaults -->
            <Style TargetType="DatePicker">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="BackgroundColor" Value="{StaticResource SurfaceColor}" />
            </Style>

            <!-- TimePicker Defaults -->
            <Style TargetType="TimePicker">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="BackgroundColor" Value="{StaticResource SurfaceColor}" />
            </Style>

            <!-- Card Frame -->
            <Style TargetType="Frame" x:Key="CardFrameStyle">
                <Setter Property="Padding" Value="16" />
                <Setter Property="Margin" Value="0,4,0,0" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="HasShadow" Value="False" />
                <Setter Property="BackgroundColor" Value="{StaticResource CardColor}" />
                <Setter Property="BorderColor" Value="{StaticResource BorderColor}" />
            </Style>

            <!-- Section Title -->
            <Style TargetType="Label" x:Key="SectionTitleStyle">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="Margin" Value="0,8,0,0"/>
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
            </Style>

            <!-- Subtitle / Help Text -->
            <Style TargetType="Label" x:Key="SubtitleLabelStyle">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
                <Setter Property="Opacity" Value="0.9" />
            </Style>

            <!-- Muted Label -->
            <Style TargetType="Label" x:Key="MutedLabelStyle">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
                <Setter Property="Opacity" Value="0.9" />
            </Style>

            <!-- Primary Button -->
            <Style TargetType="Button" x:Key="PrimaryButtonStyle">
                <Setter Property="Margin" Value="0,10,0,0" />
                <Setter Property="Padding" Value="14,10" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                <Setter Property="TextColor" Value="#1E1E1E" />
            </Style>

            <!-- Secondary Button -->
            <Style TargetType="Button" x:Key="SecondaryButtonStyle">
                <Setter Property="Margin" Value="0,6,6,0" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="BackgroundColor" Value="{StaticResource SurfaceColor}" />
                <Setter Property="BorderColor" Value="{StaticResource BorderColor}" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
            </Style>

            <!-- Status Message -->
            <Style TargetType="Label" x:Key="StatusMessageStyle">
                <Setter Property="TextColor" Value="{StaticResource CoralColor}" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <!-- Success Message -->
            <Style TargetType="Label" x:Key="SuccessMessageStyle">
                <Setter Property="TextColor" Value="{StaticResource SuccessColor}" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <!-- Arlo Bubble -->
            <Style TargetType="Frame" x:Key="ArloBubbleStyle">
                <Setter Property="Padding" Value="14" />
                <Setter Property="Margin" Value="0,6,40,0" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="HasShadow" Value="False" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                <Setter Property="HorizontalOptions" Value="Start" />
            </Style>

            <!-- User Bubble -->
            <Style TargetType="Frame" x:Key="UserBubbleStyle">
                <Setter Property="Padding" Value="14" />
                <Setter Property="Margin" Value="40,6,0,0" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="HasShadow" Value="False" />
                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                <Setter Property="HorizontalOptions" Value="End" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>

</Application>